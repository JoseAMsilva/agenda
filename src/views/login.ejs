<%- include('includes/head.ejs') %>
<%- include('includes/nav.ejs') %>

<div class="container">
    <div class="row">
        <div class="col-lg2"></div>

        <div class="col-lg8 my-3" >
            <h1 class="text-center">Cirar conta ou Login</h1>
            <p class="text-center lead">Faça login ou crie sua conta</p>

            <%- include('includes/messages'); %>

            <div class="row">

                <div class="col-lg my-5">
                    <h4>Faça seu cadastro</h4>
                    <form class="form-cadastro" action="/login/register" method="POST">
                        <input type="hidden" name="_csrf" value=<%= csrfToken %>>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="email">
                        </div>
                        <div class="mb-3 response-email-cadastro"></div>
                        <div class="mb-3">
                            <label>Senha</label>
                            <input type="password" class="form-control" name="senha">
                        </div>
                        <div class="mb-3 response-senha-cadastro"></div>
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input show-password-cadastro" id="exampleCheck1">
                            <label>Mostrar senha</label>
                        </div>
                        <button type="submit" class="btn btn-primary">Criar minha conta</button>
                    </form>
                </div>

                <div class="col-lg my-5">
                    <h4>Fazer login</h4>
                    <form class="form-login" action="/login/login" method="POST">
                        <input type="hidden" name="_csrf" value=<%= csrfToken %>>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="email">
                        </div>
                        <div class="mb-3 response-email-login"></div>
                        <div class="mb-3">
                            <label>Senha</label>
                            <input type="password" class="form-control" name="senha">
                        </div>
                        <div class="mb-3 response-senha-login"></div>
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input show-password-login" id="exampleCheck1">
                            <label>Mostrar senha</label>
                        </div>
                        <button type="submit" class="btn btn-primary">Entrar</button>
                    </form>
                </div>
        
            </div>
        </div>

        <div class="col-lg2"></div>
    </div>
</div>

<%- include('includes/footer.ejs') %>