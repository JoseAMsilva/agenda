<%- include('includes/head.ejs') %>
<%- include('includes/nav.ejs') %>

<div class="container">
    <div class="row">
        <div class="col-lg2"></div>

        <div class="col-lg8 my-3" >
            <h1 class="text-center">Contato</h1>
            <p class="text-center lead">Adicione ou edite um contato abaixo</p>

            <%- include('includes/messages')%>

            <% if(contato._id){ %>
                <form class="form-contato" action="/contato/<%= contato._id %>" method="POST">
            <% } else {%>
                <form class="form-contato" action="/contato/register" method="POST">
            <% } %>
            
                <input type="hidden" name="_csrf" value=<%= csrfToken %>>
                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input value="<%= contato.nome %>" type="text" class="form-control" name="nome">
                </div>
                <div class="mb-3 response-nome"></div>
                <div class="mb-3">
                    <label class="form-label">Sobrenome</label>
                    <input value="<%= contato.sobrenome %>" type="text" class="form-control" name="sobrenome">
                </div>
                <div class="mb-3 response-sobrenome"></div>
                <div class="mb-3">
                    <label class="form-label">E-mail</label>
                    <input value="<%= contato.email %>" type="email" class="form-control" name="email">
                </div>
                <div class="mb-3 response-email"></div>
                <div class="mb-3">
                    <label class="form-label">Telefone</label>
                    <input value="<%= contato.telefone %>" type="tel" class="form-control" name="telefone">
                </div>
                <div class="mb-3 response-telefone"></div>
                <button type="submit" class="btn btn-primary">Salvar</button>
            </form>

        </div>

        <div class="col-lg2"></div>
    </div>
</div>

<%- include('includes/footer.ejs') %>